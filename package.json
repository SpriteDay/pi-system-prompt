{
  "name": "pi-extension-template",
  "version": "0.0.1-alpha",
  "packageManager": "pnpm@11.5.2",
  "private": true,
  "scripts": {
    "fmt": "biome format --write ./src && eslint ./src --fix",
    "lint": "biome lint ./src && eslint ./src",
    "ts": "tsc --noEmit"
